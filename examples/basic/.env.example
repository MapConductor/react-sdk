# API keys used by the basic example.
# For the published demo site these are embedded at build time by
# .github/workflows/deploy-basic-example.yml from GitHub Actions secrets
# of the same names.

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# ArcGIS Location Platform API Key
# Get your API key from: https://location.arcgis.com/
VITE_ARCGIS_API_KEY=your_api_key_here

# Mapbox Access Token
# Get your token from: https://account.mapbox.com/
VITE_MAPBOX_ACCESS_TOKEN=your_access_token_here

# HERE Maps API Key
# Get your API key from: https://platform.here.com/
VITE_HERE_API_KEY=your_api_key_here
